# Resonance-Missile 环境配置示例
# 复制此文件为 .env 并根据实际环境修改

# 通信中枢
HUB_HOST=0.0.0.0
HUB_PORT=8000

# 场域感知权重 (谐振调谐论：λ需通过社会协商确定)
LAMBDA_U=0.4
LAMBDA_D=0.2
LAMBDA_A=0.4

# 翻转点检测阈值
A_INERT_THRESHOLD=0.01
A_BOUNDARY_LOW=0.12
A_BOUNDARY_HIGH=0.9
U_DELTA_REVERSAL=-0.05

# 调谐引擎参数
TUNING_ALPHA=0.1
TUNING_BETA=0.05
TUNING_GAMMA=0.02
INITIAL_TEMPERATURE=1.0

# 工具理性悖论防范
HUMAN_APPROVAL_REQUIRED=true
MAX_AUTO_FIX_ATTEMPTS=0

# 审计
AUDIT_LOG_PATH=audit.jsonl

# 日志级别
LOG_LEVEL=INFO

# Redis 配置（可选）
REDIS_URL=redis://localhost:6379/0

# ThinkCheck 老实验台路径（可选）
THINKCHECK_PATH=../thinkcheck-agent-v6